FROM ghcr.io/mlflow/mlflow:v3.11.1-full

WORKDIR /app

# LightGBM trên Linux cần libgomp1 (OpenMP)
RUN apt-get update && \
    apt-get install -y --no-install-recommends libgomp1 && \
    rm -rf /var/lib/apt/lists/*

# requirements.txt nằm ở VinuniDatathon/ (context là ..)
COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r /tmp/requirements.txt

ENV PYTHONUNBUFFERED=1

# Copy mã nguồn vào image (path tương đối với context = VinuniDatathon/)
COPY report_2026_6_19/api/      /app/report_2026_6_19/api/
COPY report_2026_6_19/scripts/  /app/report_2026_6_19/scripts/